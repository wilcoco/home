{
  "public": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "directoryListing": false,
  "headers": [
    {
      "source": "**/*.@(html)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    },
    {
      "source": "assets/**",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
